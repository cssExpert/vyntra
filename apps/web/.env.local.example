# Copy this file to .env.local and adjust if needed.

PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# lvh.me resolves all *.lvh.me to 127.0.0.1 — no hosts-file setup needed locally
# CMS subdomain example: http://acme.lvh.me:3000
NEXT_PUBLIC_PLATFORM_DOMAIN=lvh.me

# Comma-separated hostnames that serve the admin dashboard.
# Leave empty locally (localhost is always allowed).
# Production examples:
#   NEXT_PUBLIC_APP_DOMAIN=app.vyntra.com
#   NEXT_PUBLIC_APP_DOMAIN=app.vyntra.com,admin.vyntra.com
NEXT_PUBLIC_APP_DOMAIN=
