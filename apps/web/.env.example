# Copy this file to .env.local and adjust if needed.

# URL of the NestJS API server
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Platform domain used to build CMS subdomain URLs.
# The value you set here determines the URL pattern for public CMS sites.
#
# Option A — localhost (Chrome / Edge only on Windows; all browsers on Mac/Linux)
#   NEXT_PUBLIC_PLATFORM_DOMAIN=localhost
#   Admin dashboard : http://localhost:3000
#   CMS site (Acme) : http://acme.localhost:3000
#   CMS site (Bloom): http://bloom.localhost:3000
#
# Option B — lvh.me  (recommended: works on all browsers and OSes, no setup needed)
#   lvh.me is a public wildcard DNS that resolves *.lvh.me → 127.0.0.1
#   NEXT_PUBLIC_PLATFORM_DOMAIN=lvh.me
#   Admin dashboard : http://localhost:3000
#   CMS site (Acme) : http://acme.lvh.me:3000
#   CMS site (Bloom): http://bloom.lvh.me:3000
#
# Production — your actual platform domain
#   NEXT_PUBLIC_PLATFORM_DOMAIN=vyntra.com
#   CMS site (Acme) : https://acme.vyntra.com
NEXT_PUBLIC_PLATFORM_DOMAIN=localhost

# Comma-separated hostnames that serve the admin dashboard.
# Leave empty locally (localhost is always treated as the admin domain).
# Production example: NEXT_PUBLIC_APP_DOMAIN=app.vyntra.com
NEXT_PUBLIC_APP_DOMAIN=
