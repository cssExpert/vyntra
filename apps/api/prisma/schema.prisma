// Vyntra API — Prisma Schema
// Multi-tenant SaaS: super admin manages organizations, users, packages & module
// entitlements. Companies (organizations) access only the modules their package grants.
// MVP modules: CMS + CRM.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════════════════════════
//  Core: Users & RBAC
// ════════════════════════════════════════════════════════════════════

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  password       String? // bcrypt hash; null until set
  superAdmin     Boolean   @default(false) // platform-level god mode
  isActive       Boolean   @default(true)
  lastLogin      DateTime?
  organizationId String? // null for super admins
  locale         String? // preferred UI language (e.g. "en", "hi", "fr"); null = inherit org default
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  organization Organization? @relation("OrganizationUsers", fields: [organizationId], references: [id], onDelete: SetNull)
  roles        UserRole[]
  tasks        Task[]
  comments     Comment[]
  auditLogs    AuditLog[]

  @@index([organizationId])
  @@map("users")
}

// A user's role within a given organization (or platform-wide when org is null).
model UserRole {
  id             String   @id @default(cuid())
  role           Role
  userId         String
  organizationId String?
  createdAt      DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, role])
  @@index([userId])
  @@index([organizationId])
  @@map("user_roles")
}

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  EDITOR
  USER
  VIEWER
}

// ════════════════════════════════════════════════════════════════════
//  Organizations (tenants / companies)
// ════════════════════════════════════════════════════════════════════

model Organization {
  id        String   @id @default(cuid())
  name      String
  legalName String? // registered legal / business name
  industry  String? // industry or domain vertical
  address   String? // business address (single-line / multi-line)
  slug      String   @unique
  email     String?
  phone     String?
  website   String?
  isActive  Boolean  @default(true)
  maxUsers  Int      @default(5) // hard cap; effective limit = min(this, package.maxUsers)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Branding & Settings
  logoUrl              String?
  darkLogoUrl          String?
  faviconUrl           String?
  primaryColor         String  @default("#3b82f6")
  secondaryColor       String  @default("#8b5cf6")
  accentColor          String  @default("#ec4899")
  emailNotifications   Boolean @default(true)
  slackNotifications   Boolean @default(false)
  themeSwitcherEnabled Boolean @default(false)

  // Internationalization & Localization
  defaultLocale String  @default("en") // company-wide default UI language
  timezone      String? // org-specific timezone (nullable)

  // Public site language settings
  siteLanguages       String[] @default(["en"]) // enabled language codes for the public site
  defaultSiteLanguage String   @default("en") // default language shown to visitors

  // Domain / hosting
  subdomain               String? @unique // e.g. "acme" → acme.vyntra.com; set by super admin
  customDomain            String? @unique // e.g. "acme.com"; set by super admin or org admin
  customDomainVerified    Boolean @default(false)
  domainVerificationToken String? @unique

  // Relations
  users        User[]        @relation("OrganizationUsers")
  userRoles    UserRole[]
  subscription Subscription?
  auditLogs    AuditLog[]

  // Theme
  activeThemeId String?
  activeTheme   Theme?  @relation("OrgActiveTheme", fields: [activeThemeId], references: [id], onDelete: SetNull)
  themes        Theme[] @relation("OrgCustomThemes")

  // CMS (org-scoped)
  pages              Page[]
  blogs              Blog[]
  blogCategories     BlogCategory[]
  comments           Comment[]
  media              Media[]
  websiteConfigs     WebsiteConfig[]
  menus              Menu[]
  layouts            Layout[]
  cmsForms           CmsForm[]
  systemPageSettings SystemPageSettings[]
  tags               Tag[]
  tagAssignments     TagAssignment[]

  // CRM (org-scoped)
  leads      Lead[]
  contacts   Contact[]
  campaigns  Campaign[]
  tasks      Task[]
  activities Activity[]

  // Store (org-scoped)
  storeAttributes StoreAttribute[]
  products        Product[]
  categories      ProductCategory[]
  productReviews  ProductReview[]
  storeCustomers  StoreCustomer[]
  orders          Order[]
  payments        Payment[]
  coupons         CouponCode[]
  refunds         Refund[]
  storeCredits    StoreCreditTransaction[]
  rewardPoints    RewardPointTransaction[]
  inventory       Inventory[]

  @@map("organizations")
}

// ════════════════════════════════════════════════════════════════════
//  Packages (plans) & Module entitlements
// ════════════════════════════════════════════════════════════════════

// Catalog of platform modules. Stored in DB so new modules can be added
// without schema changes; the `key` is the contract used for access checks.
model Module {
  id          String   @id @default(cuid())
  key         String   @unique // "CMS", "CRM", ...
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  packages PackageModule[]

  @@map("modules")
}

// A purchasable/assignable plan. Super admin creates these; companies are
// assigned one via a Subscription. The set of modules a package includes
// determines what the company can access.
model Package {
  id           String       @id @default(cuid())
  name         String       @unique
  slug         String       @unique
  description  String?
  priceCents   Int          @default(0)
  billingCycle BillingCycle @default(MONTHLY)
  maxUsers     Int          @default(5)
  isActive     Boolean      @default(true)
  isPublic     Boolean      @default(true) // visible for future self-signup
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  modules       PackageModule[]
  subscriptions Subscription[]

  @@map("packages")
}

// Join: which modules a package grants.
model PackageModule {
  id        String @id @default(cuid())
  packageId String
  moduleId  String

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  module  Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([packageId, moduleId])
  @@index([packageId])
  @@index([moduleId])
  @@map("package_modules")
}

enum BillingCycle {
  MONTHLY
  YEARLY
  LIFETIME
}

// An organization's current plan assignment + billing lifecycle.
model Subscription {
  id             String             @id @default(cuid())
  organizationId String             @unique
  packageId      String
  status         SubscriptionStatus @default(ACTIVE)
  billingEmail   String?
  startDate      DateTime           @default(now())
  endDate        DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  package      Package      @relation(fields: [packageId], references: [id])

  @@index([packageId])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAUSED
  CANCELLED
  EXPIRED
}

// ════════════════════════════════════════════════════════════════════
//  Audit logging
// ════════════════════════════════════════════════════════════════════

model AuditLog {
  id             String   @id @default(cuid())
  action         String // e.g. "POST /api/admin/organizations"
  userId         String?
  organizationId String?
  resourceType   String?
  resourceId     String?
  statusCode     Int?
  changes        Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ════════════════════════════════════════════════════════════════════
//  CMS (org-scoped) — controllers implemented in a later phase
// ════════════════════════════════════════════════════════════════════

model Theme {
  id          String  @id @default(cuid())
  name        String
  description String?
  thumbnail   String?
  identifier  String  @default("shopingo")
  isGlobal    Boolean @default(false)
  orgId       String?

  organization  Organization?  @relation("OrgCustomThemes", fields: [orgId], references: [id], onDelete: Cascade)
  activeForOrgs Organization[] @relation("OrgActiveTheme")
  pages         Page[]         @relation("PageTheme")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([isGlobal])
  @@map("themes")
}

model Layout {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  isDefault      Boolean  @default(false)
  navMenuId      String?
  footerColumns  Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pages        Page[]

  @@index([organizationId])
  @@map("layouts")
}

model Page {
  id             String    @id @default(cuid())
  title          String
  slug           String
  content        String?
  metaDesc       String?
  metaKeywords   String?
  published      Boolean   @default(false)
  publishedAt    DateTime?
  isLandingPage  Boolean   @default(false)
  organizationId String
  layoutId       String?
  themeId        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  layout       Layout?           @relation(fields: [layoutId], references: [id], onDelete: SetNull)
  theme        Theme?            @relation("PageTheme", fields: [themeId], references: [id], onDelete: SetNull)
  comments     Comment[]
  translations PageTranslation[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([themeId])
  @@map("pages")
}

model PageTranslation {
  id           String  @id @default(cuid())
  pageId       String
  lang         String
  title        String
  content      String?
  metaDesc     String?
  metaKeywords String?

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, lang])
  @@index([pageId])
  @@map("page_translations")
}

// Page Settings (SEO / Open Graph / Favicon / Scripts / Styles) for a system page —
// an app-driven storefront route (product listing, product detail, …) as opposed to
// a CMS page. Keyed by `pageType` (see SystemPageType in the web app) rather than a
// slug, since system pages have no Page row. One row per org per page type.
model SystemPageSettings {
  id             String @id @default(cuid())
  organizationId String
  pageType       String // e.g. "product-listing"

  // SEO
  metaTitle    String?
  metaDesc     String?
  metaKeywords String?
  noIndex      Boolean @default(false)

  // Open Graph
  ogTitle       String?
  ogDescription String?
  ogType        String  @default("website")
  ogUrl         String?
  ogImage       String?

  // Favicon
  faviconUrl String?

  // Free-form settings whose shape depends on `pageType` — lets each system
  // page (product-listing today, product-details/… later) grow its own
  // extra config from the same generic Page Settings panel without a schema
  // migration per field. product-listing currently stores { productsPerPage }.
  customSettings Json?

  // Scripts
  headScript String?
  bodyScript String?

  // Styles
  customCss String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, pageType])
  @@index([organizationId])
  @@map("system_page_settings")
}

model Blog {
  id             String    @id @default(cuid())
  title          String
  subtitle       String?
  slug           String
  body           String?
  excerpt        String?
  coverImage     String?
  author         String?
  category       String?
  seoTitle       String?
  metaDesc       String?
  keywords       String?
  published      Boolean   @default(false)
  publishedAt    DateTime?
  visibility     String    @default("public")
  allowComments  Boolean   @default(true)
  isFeatured     Boolean   @default(false)
  pinToTop       Boolean   @default(false)
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  comments     Comment[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("blogs")
}

model BlogCategory {
  id             String   @id @default(cuid())
  name           String
  slug           String
  description    String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("blog_categories")
}

// Shared, org-scoped tag catalog — used by blogs, products, and (eventually)
// other taggable entities. Assignment tracked by TagAssignment, not by
// duplicating tag names onto each entity.
model Tag {
  id             String   @id @default(cuid())
  name           String
  slug           String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignments  TagAssignment[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("tags")
}

// One shared assignment table for every taggable entity, discriminated by
// entityType ("blog" | "product" | "page" — see TagEntityType in the API).
// entityId is polymorphic (no FK, since it targets a different table per
// entityType) — entity delete paths must clean up their own assignments via
// TagsService.removeAssignmentsFor.
model TagAssignment {
  id             String   @id @default(cuid())
  tagId          String
  entityType     String
  entityId       String
  organizationId String
  createdAt      DateTime @default(now())

  tag          Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([tagId, entityType, entityId])
  @@index([entityType, entityId])
  @@index([organizationId])
  @@map("tag_assignments")
}

model Comment {
  id             String        @id @default(cuid())
  body           String
  status         CommentStatus @default(PENDING)
  authorName     String?
  authorEmail    String?
  pageId         String?
  blogId         String?
  userId         String?
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  page         Page?        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  blog         Blog?        @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("comments")
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
}

model Media {
  id             String   @id @default(cuid())
  url            String
  fileName       String
  fileType       String
  size           Int?
  module         String   @default("cms")
  subtype        String?
  provider       String   @default("local")
  uploadedById   String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, module])
  @@map("media")
}

model WebsiteConfig {
  id             String   @id @default(cuid())
  key            String
  value          String?
  description    String?
  organizationId String
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("website_config")
}

model Menu {
  id             String       @id @default(cuid())
  name           String
  menuType       String       @default("navigation")
  slug           String
  visibility     String[]     @default(["all"])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items          MenuItem[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("menus")
}

model MenuItem {
  id         String   @id @default(cuid())
  label      String
  url        String
  target     String   @default("_self")
  visibility String[] @default(["all"])
  order      Int      @default(0)
  menuId     String
  menu       Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@index([menuId])
  @@map("menu_items")
}

// ════════════════════════════════════════════════════════════════════
//  CMS Forms (org-scoped)
// ════════════════════════════════════════════════════════════════════

model CmsForm {
  id             String   @id @default(cuid())
  name           String
  description    String?
  slug           String
  status         String   @default("Draft")
  fields         Json     @default("[]")
  captchaEnabled Boolean  @default(false)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submissions  CmsFormSubmission[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("cms_forms")
}

model CmsFormSubmission {
  id        String   @id @default(cuid())
  formId    String
  data      Json     @default("{}")
  createdAt DateTime @default(now())

  form CmsForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@map("cms_form_submissions")
}

// ════════════════════════════════════════════════════════════════════
//  CRM (org-scoped) — controllers implemented in a later phase
// ════════════════════════════════════════════════════════════════════

model Lead {
  id             String     @id @default(cuid())
  firstName      String
  lastName       String
  email          String?
  phone          String?
  company        String?
  source         LeadSource @default(OTHER)
  status         LeadStatus @default(NEW)
  organizationId String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activities   Activity[]
  tasks        Task[]

  @@index([organizationId])
  @@map("leads")
}

enum LeadSource {
  WEBSITE
  REFERRAL
  CAMPAIGN
  PHONE
  EMAIL
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

model Contact {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String?
  phone          String?
  company        String?
  jobTitle       String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activities   Activity[]
  tasks        Task[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("contacts")
}

model Campaign {
  id             String         @id @default(cuid())
  title          String
  description    String?
  status         CampaignStatus @default(ACTIVE)
  startDate      DateTime?
  endDate        DateTime?
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("campaigns")
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?
  assignedToId   String?
  leadId         String?
  contactId      String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  assignedTo   User?        @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Activity {
  id             String       @id @default(cuid())
  type           ActivityType
  description    String?
  leadId         String?
  contactId      String?
  organizationId String
  createdAt      DateTime     @default(now())

  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("activities")
}

// ════════════════════════════════════════════════════════════════════
//  Store: Product Management
// ════════════════════════════════════════════════════════════════════

model StoreAttribute {
  id              String                @id @default(cuid())
  organizationId  String
  name            String
  attributeType   String                @default("selection") // "selection" | "color"
  fieldType       String                @default("dropdown") // "dropdown" | "multiselect" | "buttons" | "text" | "textarea"
  usedInVariation Boolean               @default(false)
  values          StoreAttributeValue[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("store_attributes")
}

model StoreAttributeValue {
  id          String  @id @default(cuid())
  attributeId String
  name        String
  colorHex    String?
  sortOrder   Int     @default(0)

  attribute StoreAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([attributeId, name])
  @@map("store_attribute_values")
}

model Product {
  id             String @id @default(cuid())
  organizationId String
  name           String
  slug           String
  sku            String
  type           String // "simple", "variable", "digital", "downloadable", "service", "subscription", "bundle", "gift_card"
  status         String @default("draft") // "draft", "active", "archived", "scheduled"

  // Descriptions & SEO
  shortDescription String?
  description      String?
  specification    String?
  seoTitle         String?
  seoDescription   String?
  seoKeywords      String?

  // Pricing & Cost
  price          Float
  compareAtPrice Float?
  costPrice      Float?

  // Stock
  stock             Int    @default(0)
  lowStockThreshold Int    @default(10)
  stockStatus       String @default("in_stock")

  // Attributes
  weight   Float?
  taxClass String?
  brand    String?

  // Media
  featuredImage String?
  media         ProductMedia[]

  // Organization
  categoryIds String[] @default([])

  // Relations
  variants   ProductVariant[]
  inventory  Inventory[]
  orderItems OrderItem[]
  reviews    ProductReview[]

  // Timestamps
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([organizationId, status])
  @@map("products")
}

model ProductVariant {
  id         String @id @default(cuid())
  productId  String
  sku        String
  attributes Json   @default("{}")

  price          Float
  compareAtPrice Float?
  costPrice      Float?

  stock    Int     @default(0)
  weight   Float?
  imageUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, sku])
  @@index([productId])
  @@map("product_variants")
}

model ProductCategory {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  slug           String
  parentId       String?

  description String?
  imageUrl    String?
  status      String  @default("active")
  sortOrder   Int     @default(0)

  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children ProductCategory[] @relation("CategoryHierarchy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([parentId])
  @@map("product_categories")
}

model ProductMedia {
  id        String  @id @default(cuid())
  productId String
  url       String
  type      String // "image", "video"
  alt       String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_media")
}

model ProductReview {
  id             String @id @default(cuid())
  organizationId String
  productId      String
  customerId     String

  rating  Int
  title   String?
  content String

  status             String  @default("pending")
  isVerifiedPurchase Boolean @default(false)
  helpfulCount       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer     StoreCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([productId])
  @@map("product_reviews")
}

// ════════════════════════════════════════════════════════════════════
//  Store: Inventory Management
// ════════════════════════════════════════════════════════════════════

model Inventory {
  id             String  @id @default(cuid())
  organizationId String
  productId      String
  variantId      String?

  warehouseLocation String?
  stock             Int
  lastUpdated       DateTime @default(now())

  product Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  history InventoryHistory[]

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, productId, variantId])
  @@index([organizationId])
  @@map("inventory")
}

model InventoryHistory {
  id          String  @id @default(cuid())
  inventoryId String
  quantity    Int
  reason      String
  notes       String?

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([inventoryId])
  @@map("inventory_history")
}

// ════════════════════════════════════════════════════════════════════
//  Store: Orders & Payments
// ════════════════════════════════════════════════════════════════════

model Order {
  id             String @id @default(cuid())
  organizationId String
  orderNumber    String

  customerId    String
  customerName  String
  customerEmail String
  customerPhone String?

  items OrderItem[]

  subtotal       Float
  discountAmount Float @default(0)
  shippingCost   Float @default(0)
  taxAmount      Float @default(0)
  total          Float

  currencyCode String  @default("USD")
  couponCode   String?

  shippingAddressId String?
  billingAddressId  String?

  shippingAddress OrderAddress? @relation("OrderShipping", fields: [shippingAddressId], references: [id], onDelete: SetNull)
  billingAddress  OrderAddress? @relation("OrderBilling", fields: [billingAddressId], references: [id], onDelete: SetNull)

  status        String @default("pending")
  paymentStatus String @default("pending")

  shippingMethod String?
  trackingNumber String?

  timeline OrderTimeline[]
  payments Payment[]
  refunds  Refund[]

  notes String?

  paidAt      DateTime?
  shippedAt   DateTime?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     StoreCustomer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@unique([organizationId, orderNumber])
  @@index([organizationId])
  @@index([customerId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  variantId String?

  productName String
  sku         String

  quantity   Int
  unitPrice  Float
  totalPrice Float

  imageUrl     String?
  variantLabel String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@map("order_items")
}

model OrderAddress {
  id      String  @id @default(cuid())
  name    String
  line1   String
  line2   String?
  city    String
  state   String
  country String
  zip     String
  phone   String?

  shippingOrders Order[] @relation("OrderShipping")
  billingOrders  Order[] @relation("OrderBilling")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("order_addresses")
}

model OrderTimeline {
  id      String  @id @default(cuid())
  orderId String
  status  String
  message String?

  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_timeline")
}

model Payment {
  id             String @id @default(cuid())
  organizationId String
  orderId        String

  amount   Float
  currency String @default("USD")
  method   String

  status        String
  transactionId String?
  receiptUrl    String?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([orderId])
  @@map("payments")
}

model Refund {
  id             String @id @default(cuid())
  organizationId String
  orderId        String

  amount Float
  reason String
  status String @default("pending")

  items RefundItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([orderId])
  @@map("refunds")
}

model RefundItem {
  id          String @id @default(cuid())
  refundId    String
  orderItemId String
  quantity    Int
  amount      Float

  refund Refund @relation(fields: [refundId], references: [id], onDelete: Cascade)

  @@index([refundId])
  @@map("refund_items")
}

// ════════════════════════════════════════════════════════════════════
//  Store: Customers & Loyalty
// ════════════════════════════════════════════════════════════════════

model StoreCustomer {
  id             String @id @default(cuid())
  organizationId String

  name      String
  email     String  @unique
  phone     String?
  avatarUrl String?

  status  String   @default("active")
  tags    String[] @default([])
  segment String?
  isVip   Boolean  @default(false)

  rewardPoints Int    @default(0)
  storeCredit  Float  @default(0)
  rewardTier   String @default("bronze")

  totalOrders       Int       @default(0)
  totalSpent        Float     @default(0)
  averageOrderValue Float     @default(0)
  lastOrderDate     DateTime?

  orders             Order[]
  creditTransactions StoreCreditTransaction[]
  rewardTransactions RewardPointTransaction[]
  reviews            ProductReview[]

  registeredAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("store_customers")
}

model StoreCreditTransaction {
  id         String  @id @default(cuid())
  customerId String
  amount     Float
  type       String
  reason     String
  orderId    String?

  expiresAt DateTime?
  createdAt DateTime  @default(now())

  customer       StoreCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String

  @@index([customerId])
  @@map("store_credit_transactions")
}

model RewardPointTransaction {
  id         String  @id @default(cuid())
  customerId String
  points     Int
  type       String
  reason     String
  orderId    String?

  expiresAt DateTime?
  createdAt DateTime  @default(now())

  customer       StoreCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String

  @@index([customerId])
  @@map("reward_point_transactions")
}

model CouponCode {
  id             String @id @default(cuid())
  organizationId String

  code  String
  type  String
  value Float

  minimumSpend      Float?
  maximumDiscount   Float?
  usageLimit        Int?
  usageCount        Int    @default(0)
  usageLimitPerUser Int?

  productIds  String[] @default([])
  categoryIds String[] @default([])

  startsAt  DateTime?
  expiresAt DateTime?
  status    String    @default("active")

  freeShipping Boolean @default(false)

  usages CouponUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("coupon_codes")
}

model CouponUsage {
  id         String @id @default(cuid())
  couponId   String
  orderId    String
  customerId String

  discountAmount Float

  createdAt DateTime @default(now())

  coupon CouponCode @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@map("coupon_usages")
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  TASK_CREATED
  STAGE_CHANGED
  OTHER
}

// ════════════════════════════════════════════════════════════════════
//  Admin Settings (platform-wide configuration)
// ════════════════════════════════════════════════════════════════════

model AdminSettings {
  id                      String  @id @default(cuid())
  siteName                String  @default("Vyntra")
  supportEmail            String  @default("support@vyntra.com")
  logoUrl                 String?
  faviconUrl              String?
  primaryColor            String  @default("#3b82f6")
  secondaryColor          String  @default("#8b5cf6")
  accentColor             String  @default("#ec4899")
  maxOrganizations        Int     @default(1000)
  maxUsersPerOrganization Int     @default(500)
  enableRegistration      Boolean @default(true)
  enableSocialAuth        Boolean @default(false)
  maintenanceMode         Boolean @default(false)

  // Email Configuration
  emailProvider  String? @default("smtp") // smtp | sendgrid | mailgun
  smtpConfig     Json? // { host, port, secure, username, password, fromEmail }
  sendgridConfig Json? // { apiKey, fromEmail }
  mailgunConfig  Json? // { apiKey, domain, fromEmail }

  // Storage Configuration
  storageProvider   String? @default("local") // local | s3 | uploadthing | vercel-blob
  s3Config          Json?
  uploadthingConfig Json?
  vercelBlobConfig  Json?

  // Internationalization & Localization
  timezone String @default("UTC") // global timezone setting

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_settings")
}
