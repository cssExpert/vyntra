# Copy this file to .env and adjust if needed.

# Database
DATABASE_URL="postgresql://vyntra:vyntra_dev_password@localhost:5432/vyntra_db"

# JWT
JWT_SECRET="vyntra-dev-secret-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="vyntra-dev-refresh-secret-change-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=3001
CORS_ORIGINS="http://localhost:3000"

# Redis
REDIS_URL="redis://localhost:6379"

# MinIO
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin123"
MINIO_BUCKET="vyntra"

# Platform domain — must match NEXT_PUBLIC_PLATFORM_DOMAIN in apps/web/.env.local
#
# Option A — localhost (Chrome/Edge only on Windows; all browsers on Mac/Linux)
#   PLATFORM_DOMAIN="localhost"
#   CMS URL: http://acme.localhost:3000
#
# Option B — lvh.me (recommended: all browsers, no setup needed)
#   PLATFORM_DOMAIN="lvh.me"
#   CMS URL: http://acme.lvh.me:3000
#
PLATFORM_DOMAIN="localhost"

# Your server's public IP — used in DNS A-record instructions shown to customers.
PLATFORM_IP="127.0.0.1"

# Google reCAPTCHA v3 — server-side secret used to verify tokens from public form submissions.
# Get keys at https://www.google.com/recaptcha/admin — must pair with
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY in apps/web/.env.local.
RECAPTCHA_SECRET_KEY=
