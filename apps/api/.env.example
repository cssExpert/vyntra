# Copy this file to .env and adjust if needed.

# Database
DATABASE_URL="postgresql://vyntra:vyntra_dev_password@localhost:5432/vyntra_db"

# JWT
JWT_SECRET="vyntra-dev-secret-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="vyntra-dev-refresh-secret-change-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=3001
CORS_ORIGINS="http://localhost:3000"

# Redis
REDIS_URL="redis://localhost:6379"

# MinIO
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin123"
MINIO_BUCKET="vyntra"

# Platform domain — lvh.me resolves all *.lvh.me to 127.0.0.1 with no hosts-file setup
# Local subdomain example: http://acme.lvh.me:3000
PLATFORM_DOMAIN="lvh.me"
PLATFORM_IP="127.0.0.1"
