{
  "name": "@vyntra/api",
  "version": "0.1.0",
  "private": true,
  "description": "Vyntra API — NestJS backend with Prisma",
  "author": "Vyntra",
  "license": "MIT",
  "scripts": {
    "dev": "nest start --watch",
    "start": "node dist/main",
    "build": "nest build",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
