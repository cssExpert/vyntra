{
  "name": "ERVFlow",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": {
    "packages": [
      "apps/*",
      "libs/*"
    ]
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @vyntra/web dev",
    "dev:api": "pnpm --filter @vyntra/api dev",
    "build": "pnpm build:types && pnpm build:web && pnpm build:api",
    "build:types": "pnpm --filter @vyntra/types build",
    "build:web": "pnpm --filter @vyntra/web build",
    "build:api": "pnpm --filter @vyntra/api build",
    "lint": "pnpm --filter @vyntra/web lint && pnpm --filter @vyntra/api lint",
    "type-check": "pnpm --filter @vyntra/web type-check && pnpm --filter @vyntra/api type-check",
    "db:up": "docker compose -f infrastructure/docker-compose.yml up -d",
    "db:down": "docker compose -f infrastructure/docker-compose.yml down",
    "db:migrate": "pnpm --filter @vyntra/api exec prisma migrate dev",
    "db:seed": "pnpm --filter @vyntra/api exec prisma db seed",
    "db:studio": "pnpm --filter @vyntra/api exec prisma studio",
    "db:push": "pnpm --filter @vyntra/api exec prisma db push",
    "db:push:reset": "pnpm --filter @vyntra/api exec prisma db push --force-reset",
    "db:generate": "pnpm --filter @vyntra/api exec prisma generate",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@nosferatu500/react-sortable-tree": "^5.0.0",
    "@tiptap/extension-font-family": "^2.27.2",
    "@tiptap/extension-text-align": "^2.27.2",
    "@uiw/react-color": "^2.10.3",
    "jszip": "^3.10.1"
  }
}
