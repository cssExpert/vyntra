{
  "name": "vyntra",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": {
    "packages": [
      "apps/*",
      "libs/*"
    ]
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @vyntra/web dev",
    "dev:app": "next dev",
    "dev:api": "pnpm --filter @vyntra/api dev",
    "build": "pnpm build:types && next build && pnpm build:api",
    "build:types": "pnpm --filter @vyntra/types build",
    "build:web": "next build",
    "build:api": "pnpm --filter @vyntra/api build",
    "lint": "next lint && pnpm --filter @vyntra/api lint",
    "type-check": "tsc --noEmit && pnpm --filter @vyntra/api type-check",
    "db:up": "docker compose -f infrastructure/docker-compose.yml up -d",
    "db:down": "docker compose -f infrastructure/docker-compose.yml down",
    "db:migrate": "pnpm --filter @vyntra/api exec prisma migrate dev",
    "db:seed": "pnpm --filter @vyntra/api exec prisma db seed",
    "db:studio": "pnpm --filter @vyntra/api exec prisma studio"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-rc.0",
    "@dnd-kit/core": "^6.3.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tiptap/extension-color": "^2",
    "@tiptap/extension-drag-handle": "2.27.2",
    "@tiptap/extension-drag-handle-react": "2.27.2",
    "@tiptap/extension-emoji": "2.27.2",
    "@tiptap/extension-highlight": "^2",
    "@tiptap/extension-image": "2.27.2",
    "@tiptap/extension-link": "^2",
    "@tiptap/extension-mention": "2.27.2",
    "@tiptap/extension-placeholder": "^2",
    "@tiptap/extension-table": "2.27.2",
    "@tiptap/extension-table-cell": "2.27.2",
    "@tiptap/extension-table-header": "2.27.2",
    "@tiptap/extension-table-row": "2.27.2",
    "@tiptap/extension-task-item": "^2",
    "@tiptap/extension-task-list": "^2",
    "@tiptap/extension-text-style": "^2",
    "@tiptap/extension-underline": "^2",
    "@tiptap/pm": "^2",
    "@tiptap/react": "^2",
    "@tiptap/starter-kit": "^2",
    "@tiptap/suggestion": "^2",
    "@types/react-datepicker": "^7.0.0",
    "immer": "^11.1.8",
    "nanoid": "^5.1.11",
    "react-datepicker": "^9.1.0",
    "react-select": "^5.10.2",
    "zustand": "^5.0.14"
  }
}
