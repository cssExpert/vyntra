# Use a flat (hoisted) node_modules layout — npm-compatible.
# The Next.js app at the repo root resolves its dependencies (next, react, etc.)
# from the hoisted root node_modules, so this must stay enabled.
node-linker=hoisted
# Install peer dependencies automatically (pnpm 9 default, made explicit).
auto-install-peers=true
# Keep installs deterministic across Windows + macOS teammates.
prefer-frozen-lockfile=false
