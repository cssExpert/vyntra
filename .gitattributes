# Normalize line endings: store LF in the repo, check out LF everywhere.
# Prevents Windows CRLF from corrupting scripts/configs shared with Mac teammates.
* text=auto eol=lf

# Shell scripts must always be LF (they break with CRLF).
*.sh text eol=lf

# Lockfiles are generated — keep diffs clean and avoid normalization churn.
pnpm-lock.yaml -diff linguist-generated

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
